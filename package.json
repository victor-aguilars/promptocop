{
  "name": "promptocop",
  "version": "1.0.0",
  "description": "A prompt linter for Claude Code — catches bad prompt patterns before they reach the model",
  "type": "module",
  "bin": {
    "promptocop": "dist/cli.js"
  },
  "main": "dist/linter.js",
  "types": "dist/linter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/linter.d.ts",
      "import": "./dist/linter.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "prompt",
    "linter",
    "claude",
    "claude-code",
    "ai"
  ],
  "author": "victor-aguilars",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/victor-aguilars/promptocop.git"
  },
  "homepage": "https://github.com/victor-aguilars/promptocop#readme",
  "bugs": {
    "url": "https://github.com/victor-aguilars/promptocop/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
